{
  "rewrites": [
    {
      "source": "/__/auth/:path*",
      "destination": "https://walkier-1b600.firebaseapp.com/__/auth/:path*"
    },
    {
      "source": "/__/firebase/:path*",
      "destination": "https://walkier-1b600.firebaseapp.com/__/firebase/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Permissions-Policy", "value": "microphone=(self)" }
      ]
    }
  ]
}
